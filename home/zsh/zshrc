# Created by Zap installer
if [ ! -f "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh" ]; then
  zsh <(curl -s https://raw.githubusercontent.com/zap-zsh/zap/master/install.zsh) --branch release-v1 --keep
fi
[ -f "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh" ] && source "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh"


plug "$HOME/.config/zsh/aliases.zsh"
plug "$HOME/.config/zsh/options.zsh"
plug "$HOME/.config/zsh/keybindings.zsh"
plug "$HOME/.config/zsh/tmp.zsh"

#plug "zap-zsh/supercharge"
#plug "zap-zsh/zap-prompt"

plug "zsh-users/zsh-syntax-highlighting"
plug "zsh-users/zsh-autosuggestions"
plug "zsh-users/zsh-completions"

plug "zsh-users/zsh-history-substring-search"
plug "Aloxaf/fzf-tab"
plug "Freed-Wu/fzf-tab-source"

# Load and initialise completion system
autoload -Uz compinit
compinit

PATH="$HOME/.local/bin/:$PATH"

# shellcheck disable=SC1090
[[ ${commands[kubectl]} ]] && source <(kubectl completion zsh)

# AWS CLI completion for zsh
if [[ -x "$(command -v aws_completer)" ]]; then
  compdef _aws aws
  function _aws {
    local IFS=$'\n'
    compadd -- "$(aws_completer "$@")"
  }
  compdef _aws aws-vault
  compdef _aws sudo
fi

autoload bashcompinit && bashcompinit
autoload -Uz compinit && compinit
complete -C 'aws_completer' aws

[[ ${commands[kubectl]} ]] && source <(kubectl completion zsh)
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.bun/bin:$PATH"
export PATH="$HOME/bin:$PATH"
export PATH="/opt/homebrew/opt/postgresql@18/bin:$PATH"

export TODO_DIR="$HOME/.sync/TheBox/inbox"
export TODO_FILE="$TODO_DIR/todo.txt"
export DONE_FILE="$TODO_DIR/done.txt"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac
# pnpm end

# mise (manages node/python/etc. version paths)
[[ -x "$(command -v mise)" ]] && eval "$(mise activate zsh)"
