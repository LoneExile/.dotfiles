# Created by Zap installer
if [ ! -f "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh" ]; then
  zsh <(curl -s https://raw.githubusercontent.com/zap-zsh/zap/master/install.zsh) --branch release-v1 --keep
fi

# Real interactive terminal only.
# Non-TTY / agent shells bail out earlier via programs.zsh.initContent (order 500).
[ -f "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh" ] && source "${XDG_DATA_HOME:-$HOME/.local/share}/zap/zap.zsh"

plug "$HOME/.config/zsh/aliases.zsh"
plug "$HOME/.config/zsh/options.zsh"
plug "$HOME/.config/zsh/keybindings.zsh"
plug "$HOME/.config/zsh/tmp.zsh" 2>/dev/null || true

plug "zsh-users/zsh-syntax-highlighting"
plug "zsh-users/zsh-autosuggestions"
plug "zsh-users/zsh-completions"
plug "zsh-users/zsh-history-substring-search"
plug "Aloxaf/fzf-tab"
plug "Freed-Wu/fzf-tab-source"

# Refresh completion dump only once per day; -C skips the security
# audit and loads the existing dump directly (~30x faster).
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
ZSH_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
mkdir -p "$ZSH_CACHE_DIR"

# kubectl completion (cached — kubectl is slow to spawn, ~150ms)
if [[ ${commands[kubectl]} ]]; then
  _kcomp="$ZSH_CACHE_DIR/kubectl_completion"
  _kver="$ZSH_CACHE_DIR/kubectl_version"
  _cur_ver="$(kubectl version --client 2>/dev/null | head -1)"
  if [[ ! -f "$_kcomp" || "$(cat "$_kver" 2>/dev/null)" != "$_cur_ver" ]]; then
    kubectl completion zsh > "$_kcomp" 2>/dev/null
    echo -n "$_cur_ver" > "$_kver"
  fi
  [[ -f "$_kcomp" ]] && source "$_kcomp"
fi

# treehouse completion (cached — same version-invalidation pattern as kubectl)
if [[ ${commands[treehouse]} ]]; then
  _thcomp="$ZSH_CACHE_DIR/treehouse_completion"
  _thver="$ZSH_CACHE_DIR/treehouse_version"
  _cur_ver="$(treehouse --version 2>/dev/null)"
  if [[ ! -f "$_thcomp" || "$(cat "$_thver" 2>/dev/null)" != "$_cur_ver" ]]; then
    treehouse completion zsh > "$_thcomp" 2>/dev/null
    echo -n "$_cur_ver" > "$_thver"
  fi
  [[ -f "$_thcomp" ]] && source "$_thcomp"
fi

# no-mistakes completion (cached — same version-invalidation pattern as kubectl)
if [[ ${commands[no-mistakes]} ]]; then
  _nmcomp="$ZSH_CACHE_DIR/no-mistakes_completion"
  _nmver="$ZSH_CACHE_DIR/no-mistakes_version"
  _cur_ver="$(no-mistakes --version 2>/dev/null)"
  if [[ ! -f "$_nmcomp" || "$(cat "$_nmver" 2>/dev/null)" != "$_cur_ver" ]]; then
    no-mistakes completion zsh > "$_nmcomp" 2>/dev/null
    echo -n "$_cur_ver" > "$_nmver"
  fi
  [[ -f "$_nmcomp" ]] && source "$_nmcomp"
fi

# AWS CLI completion
if [[ -x "$(command -v aws_completer)" ]]; then
  autoload bashcompinit && bashcompinit
  compdef _aws aws
  function _aws {
    local IFS=$'\n'
    compadd -- "$(aws_completer "$@")"
  }
  compdef _aws aws-vault
  compdef _aws sudo
  complete -C 'aws_completer' aws
fi

export TODO_DIR="$HOME/.sync/TheBox/inbox"
export TODO_FILE="$TODO_DIR/todo.txt"
export DONE_FILE="$TODO_DIR/done.txt"

export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

# NOTE: mise is activated by HM's programs.mise.enableZshIntegration.
